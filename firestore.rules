rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isDashboardValid(data) {
      return data.keys().hasAll(['config', 'prayers', 'jummah', 'announcements', 'quotes', 'lastUpdated']) 
             && data.config is map 
             && data.prayers is list 
             && data.jummah is list 
             && data.announcements is list 
             && data.quotes is list 
             && data.lastUpdated is string;
    }

    // Mosque dashboard collection
    match /mosqueData/{dashboardId} {
      allow get: if true;
      allow list: if true; // Allow listing so the directory can load mosques
      
      allow create: if isSignedIn() 
                    && isValidId(dashboardId) 
                    && isDashboardValid(incoming());
                    
      allow update: if isSignedIn() 
                    && isValidId(dashboardId) 
                    && isDashboardValid(incoming());
                    
      allow delete: if false; // The dashboard configuration cannot be deleted
    }

    // Mosque registrations collection
    match /mosqueRegistrations/{registrationId} {
      allow create: if true; // Anyone can apply for registration
      allow read, write: if isSignedIn() && request.auth.token.email == "antakajunior3@gmail.com" && request.auth.token.email_verified == true;
    }
  }
}
